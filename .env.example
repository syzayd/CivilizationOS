# Copy this file to .env and fill in keys. .env is gitignored.

# --- Brain routing ---
# PREMIUM_MODE=true  -> council debates use Claude (Tier 2). Costs a few $.
# PREMIUM_MODE=false -> entire app runs on local Ollama + free Gemini ($0).
PREMIUM_MODE=false

# Hard ceiling (USD) on Tier-2 Claude spend this process. Router refuses past this.
TIER2_BUDGET_USD=15.0

# --- Tier 0: local Ollama (free, unlimited) ---
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=qwen2.5:3b-instruct
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Tier 1: Google Gemini free tier (get key at https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Tier 2: Anthropic Claude (https://console.anthropic.com) ---
ANTHROPIC_API_KEY=
CLAUDE_MEMBER_MODEL=claude-haiku-4-5
CLAUDE_SYNTH_MODEL=claude-sonnet-4-6
